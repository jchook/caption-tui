{
  "name": "caption-tui",
  "version": "1.0.0",
  "description": "Fast image captioning TUI with autocomplete",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "caption-tui": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx index.ts",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "prepare": "tsc -p tsconfig.build.json",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write .",
    "prepack": "biome check --write . && tsc -p tsconfig.build.json"
  },
  "keywords": [
    "caption",
    "image",
    "tagging",
    "dataset",
    "tui",
    "cli",
    "autocomplete"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4",
    "typescript": "^7"
  },
  "peerDependencies": {
    "typescript": "^7"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "ink-picture": "2.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  }
}
